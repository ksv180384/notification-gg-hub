APP_NAME="notification-gg-hub"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# docker-compose overrides
HTTP_PORT=8080
HTTPS_PORT=8443
DB_PORT_FORWARD=3306
MYSQL_ROOT_PASSWORD=root

# nginx config selector (file in ./docker/nginx/)
# - default.conf    : local/dev (HTTP only)
# - prod-http.conf  : production bootstrap (HTTP only + ACME)
# - prod.conf       : production (HTTPS + redirects)
NGINX_CONF=default.conf

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Telegram logger (outbound: send message to Telegram)
TELEGRAM_LOGGER_TOKEN=
TELEGRAM_LOGGER_CHAT_ID=

# Notification hub (inbound: protect /api/notifications and /api/discord)
# Required: secret token that callers must pass as header `X-Notification-Hub-Token`
# (or `Authorization: Bearer <token>`).
NOTIFICATION_HUB_INGRESS_TOKEN=

# Optional: comma-separated allowlist of IPs/CIDRs (e.g. "203.0.113.10,203.0.113.0/24").
# If empty, only token auth is enforced.
NOTIFICATION_HUB_ALLOWED_IPS=

# Optional: timeout (seconds) for outbound POST to a Discord webhook URL.
# NOTIFICATION_HUB_DISCORD_TIMEOUT=10

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=secret

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

MAIL_MAILER=log
