APP_NAME="notification-gg-hub"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# docker-compose overrides
APP_PORT=8080
DB_PORT_FORWARD=3306
MYSQL_ROOT_PASSWORD=root

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Telegram logger (outbound: send message to Telegram)
TELEGRAM_LOGGER_TOKEN=
TELEGRAM_LOGGER_CHAT_ID=

# Telegram logger (inbound: protect /api/telegram-log)
# Required: secret token that callers must pass as header `X-Telegram-Logger-Token`
# (or `Authorization: Bearer <token>`).
TELEGRAM_LOGGER_INGRESS_TOKEN=

# Optional: comma-separated allowlist of IPs/CIDRs (e.g. "203.0.113.10,203.0.113.0/24").
# If empty, only token auth is enforced.
TELEGRAM_LOGGER_ALLOWED_IPS=

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=secret

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

MAIL_MAILER=log
